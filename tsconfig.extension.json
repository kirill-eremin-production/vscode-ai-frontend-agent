{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node", "vscode"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@ext/*": ["./src/extension/*"]
    }
  },
  "include": ["src/extension/**/*.ts", "tests/globals.d.ts"]
}
