{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@app/*": ["./src/webview/app/*"],
      "@features/*": ["./src/webview/features/*"],
      "@shared/*": ["./src/webview/shared/*"]
    }
  },
  "include": ["src/webview/**/*"]
}
